{
  "name": "jackbox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app lib tests e2e next.config.ts playwright.config.ts eslint.config.mjs postcss.config.mjs vitest.config.mts",
    "typecheck": "tsc --noEmit",
    "test": "TMPDIR=/tmp TMP=/tmp TEMP=/tmp vitest",
    "test:run": "TMPDIR=/tmp TMP=/tmp TEMP=/tmp vitest run",
    "test:e2e": "TMPDIR=/tmp TMP=/tmp TEMP=/tmp PLAYWRIGHT_BROWSERS_PATH=/tmp/ms-playwright JACKBOX_FIRECRAWL_MODE=fixture playwright test"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.15.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
